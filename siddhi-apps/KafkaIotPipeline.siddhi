/* CR105_R18: door open + motion + after 22:00 -> security alert */
from IotInStream[roomId == 'CR-105' and doorOpen == true and motion == true]
select
  'CR105_R18' as ruleId,
  buildingId,
  roomId,
  'SECURITY_ALERT' as action,
  temp,
  co2,
  0.0 as rise,
  'DUP Door opened with motion after 22:00: security alert' as msg,
  ts
having (ts % 86400000L) >= 79200000L
insert into Alerts;
/* CR105_R19: door closed + no motion 30s -> lights off */
from IotInStream[roomId == 'CR-105' and doorOpen == false and motion == false]
#window.time(30 sec)
select
  'CR105_R19' as ruleId,
  buildingId,
  roomId,
  'LIGHTS_OFF' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'DUP Door closed and no motion for 30s: lights off' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR105_R19']
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR105_R20: motion + CO2 > 900 + temp > 26 -> HVAC boost */
from IotInStream[roomId == 'CR-105' and motion == true and co2 > 900L and temp > 26.0]
select
  'CR105_R20' as ruleId,
  buildingId,
  roomId,
  'HVAC_BOOST' as action,
  temp,
  co2,
  0.0 as rise,
  'DUP Motion, CO2 > 900ppm and temp > 26C: HVAC boost' as msg,
  ts
insert into Alerts;
/* CR105_R21: motion + temp < 20C for 5s -> setpoint +1C */
from IotInStream[roomId == 'CR-105' and motion == true]
#window.time(5 sec)
select
  'CR105_R21' as ruleId,
  buildingId,
  roomId,
  'SETPOINT_INC' as action,
  max(temp) as temp,
  max(co2) as co2,
  (max(temp) - min(temp)) as rise,
  'DUP Motion and temp < 20C for 5s: increase setpoint by 1C' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR105_R21' and maxTemp < 20.0]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR105_R22: motion + lux > 750 for 5s -> LIGHTS_DIM_50 */
from IotInStream[roomId == 'CR-105' and motion == true]
#window.time(5 sec)
select
  'CR105_R22' as ruleId,
  buildingId,
  roomId,
  'LIGHTS_DIM_50' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'DUP Motion and lux > 750 for 5s: dim lights' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR105_R22' and minLux > 750L and maxLux <= 1000L]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR105_R23: motion + lux > 1000 for 5s -> LIGHTS_DIM_30 */
from IotInStream[roomId == 'CR-105' and motion == true]
#window.time(5 sec)
select
  'CR105_R23' as ruleId,
  buildingId,
  roomId,
  'LIGHTS_DIM_30' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'DUP Motion and lux > 1000 for 5s: dim lights' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR105_R23' and minLux > 1000L]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR105_R24: motion + lux < 150 for 5s -> lights on 100% */
from IotInStream[roomId == 'CR-105' and motion == true]
#window.time(5 sec)
select
  'CR105_R24' as ruleId,
  buildingId,
  roomId,
  'LIGHTS_ON_100' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'DUP Motion and lux < 150 for 5s: lights on 100%' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR105_R24' and maxLux < 150L]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

