@App:name("KafkaIotPipeline")

/* --------- INPUT: Kafka -> IotInStream (JSON) --------- */
@source(
  type='kafka',
  bootstrap.servers='kafka:9093',
  topic.list='iot.input',
  group.id='siddhi-json',
  threading.option='single.thread',
  optional.configuration='auto.offset.reset=earliest',
  @map(type='json', fail.on.missing.attribute='false')
)
define stream IotInStream (
  buildingId string,
  roomId string,
  deviceId string,
  ts long,
  temp double,
  motion bool,
  co2 long,
  lux long,
  doorOpen bool
);

/* --------- OUTPUT: Kafka -> iot.alerts (JSON) --------- */
@sink(
  type='kafka',
  bootstrap.servers='kafka:9093',
  topic='iot.alerts',
  @map(type='json')
)
define stream Alerts (
  ruleId string,
  buildingId string,
  roomId string,
  action string,
  temp double,
  co2 long,
  rise double,
  msg string,
  ts long
);

/* --------- Internal aggregation stream --------- */
define stream RuleAgg (
  ruleId string,
  buildingId string,
  roomId string,
  action string,
  temp double,
  co2 long,
  rise double,
  msg string,
  ts long,
  minTemp double,
  maxTemp double,
  minCo2 long,
  maxCo2 long,
  minLux long,
  maxLux long
);

/* ================= ORIGINAL 60 RULES WITH SECONDS WINDOWS ================= */

/* ================= CR-101 rules ================= */
/* CR101_R01: after 18:00 + no motion 10s + door closed -> lights off + HVAC eco */
from IotInStream[roomId == 'CR-101' and motion == false and doorOpen == false]
#window.time(10 sec)
select
  'CR101_R01' as ruleId,
  buildingId,
  roomId,
  'LIGHTS_OFF_HVAC_ECO' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'After 18:00, no motion for 10s and door closed: lights off + HVAC eco mode' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR101_R01' and (ts % 86400000L) >= 64800000L]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR101_R02: motion + CO2 > 1000ppm for 5s -> HVAC boost */
from IotInStream[roomId == 'CR-101' and motion == true]
#window.time(5 sec)
select
  'CR101_R02' as ruleId,
  buildingId,
  roomId,
  'HVAC_BOOST' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'Motion and CO2 > 1000ppm for 5s: HVAC boost' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR101_R02' and minCo2 > 1000L]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR101_R03: motion + temp > 26C for 10s -> setpoint -1C */
from IotInStream[roomId == 'CR-101' and motion == true]
#window.time(10 sec)
select
  'CR101_R03' as ruleId,
  buildingId,
  roomId,
  'SETPOINT_DEC' as action,
  max(temp) as temp,
  max(co2) as co2,
  (max(temp) - min(temp)) as rise,
  'Motion and temp > 26C for 10s: decrease setpoint by 1C' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR101_R03' and minTemp > 26.0]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR101_R04: motion + lux < 200 for 5s -> LIGHTS_ON_80 */
from IotInStream[roomId == 'CR-101' and motion == true]
#window.time(5 sec)
select
  'CR101_R04' as ruleId,
  buildingId,
  roomId,
  'LIGHTS_ON_80' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'Motion and lux < 200 for 5s: lights on' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR101_R04' and maxLux < 200L]
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR101_R05: door open + no motion 25s -> close door */
from IotInStream[roomId == 'CR-101' and doorOpen == true and motion == false]
#window.time(25 sec)
select
  'CR101_R05' as ruleId,
  buildingId,
  roomId,
  'DOOR_CLOSE' as action,
  max(temp) as temp,
  max(co2) as co2,
  0.0 as rise,
  'Door open and no motion for 25s: close door' as msg,
  max(ts) as ts,
  min(temp) as minTemp,
  max(temp) as maxTemp,
  min(co2) as minCo2,
  max(co2) as maxCo2,
  min(lux) as minLux,
  max(lux) as maxLux
group by buildingId, roomId
insert into RuleAgg;

from RuleAgg[ruleId == 'CR101_R05']
select ruleId, buildingId, roomId, action, temp, co2, rise, msg, ts
insert into Alerts;

/* CR101_R06: door open + motion + after 22:00 -> security alert */
from IotInStream[roomId == 'CR-101' and doorOpen == true and motion == true]
select
  'CR101_R06' as ruleId,
  buildingId,
  roomId,
  'SECURITY_ALERT' as action,
  temp,
  co2,
  0.0 as rise,
  'Door opened with motion after 22:00: security alert' as msg,
  ts
having (ts % 86400000L) >= 79200000L
insert into Alerts;
/* CR101_R07: door closed + no motion 30s -> lights off */
from IotInStream[roomId == 'CR-101' and doorOpen == false and motion == false]
#window.time(30 sec)
